---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { SITE_TITLE, SITE_METADATA } from '../consts';
import JsonLd from './JsonLd.astro';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	ogType?: 'website' | 'article';
	noindex?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image, ogType = 'website', noindex = false } = Astro.props;
// Apply the "%s | Coalbanks" template unless the page already carries a
// branded suffix (all hand-written page titles currently do).
const finalTitle = title
	? title.includes('|')
		? title
		: SITE_METADATA.title.template.replace('%s', title)
	: SITE_METADATA.title.default;
const finalDescription = description || SITE_METADATA.description;
const finalImage = image || SITE_METADATA.openGraph.images[0].url;
// Resolve against the site root, not the current page, so relative
// frontmatter paths can't produce /blog/<image> style URLs.
const imageURL = new URL(finalImage, Astro.site || Astro.url.origin);
const isDefaultImage = !image;
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';

---

<!-- Global Metadata -->
<meta charset="utf-8" />

<!-- Load Google Fonts (Locally via Fontsource) -->
<!-- Previously loaded via CDN, now handled in global.css -->

<meta name="viewport" content="width=device-width,initial-scale=1" />

<!-- Fonts are handled globally inside global.css via FontSource -->

<meta name="robots" content={robotsContent} />
<meta name="author" content={SITE_METADATA.authors[0].name} />
<meta name="creator" content={SITE_METADATA.creator} />
<meta name="publisher" content={SITE_METADATA.publisher} />

<!-- Geographic Targeting for Local SEO -->
<meta name="geo.region" content="CA-AB" />
<meta name="geo.placename" content="Lethbridge" />
<meta name="geo.position" content="49.6956;-112.8335" />
<meta name="ICBM" content="49.6956, -112.8335" />

<!-- Theme Script -->
<script is:inline>
  function applyTheme() {
    let savedTheme = null;
    try {
      // localStorage can throw (sandboxed iframes, blocked storage); dark
      // mode should degrade to the system preference, not crash.
      savedTheme = localStorage.getItem('theme');
    } catch {}
    const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    const initialTheme = savedTheme || systemTheme;

    document.documentElement.classList.toggle('dark', initialTheme === 'dark');
  }

  // Apply immediately
  applyTheme();

  // Re-apply after view transitions
  document.addEventListener('astro:after-swap', applyTheme);
</script>

<!-- Favicon -->
{SITE_METADATA.icons.icon.map((icon) => (
  <link
    rel="icon"
    type={icon.type}
    sizes={icon.sizes}
    href={icon.url}
  />
))}
{SITE_METADATA.icons.apple.map((icon) => (
  <link
    rel="apple-touch-icon"
    sizes={icon.sizes}
    href={icon.url}
  />
))}
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="theme-color" content="#8B6914" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#B89A3D" media="(prefers-color-scheme: dark)" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{finalTitle}</title>
<meta name="title" content={finalTitle} />
<meta name="description" content={finalDescription} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={Astro.url} />
<meta property="og:site_name" content={SITE_METADATA.openGraph.siteName} />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:image" content={imageURL} />
{isDefaultImage && (
  <>
    <meta property="og:image:width" content={SITE_METADATA.openGraph.images[0].width.toString()} />
    <meta property="og:image:height" content={SITE_METADATA.openGraph.images[0].height.toString()} />
    <meta property="og:image:alt" content={SITE_METADATA.openGraph.images[0].alt} />
  </>
)}
<meta property="og:locale" content="en_CA" />

<!-- Twitter (X keys off name=, not property=) -->
<meta name="twitter:card" content={SITE_METADATA.twitter.card} />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={finalTitle} />
<meta name="twitter:description" content={finalDescription} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:creator" content={SITE_METADATA.twitter.creator} />

<!-- JSON-LD Structured Data -->
<JsonLd type="LocalBusiness" />
