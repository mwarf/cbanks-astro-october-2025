---
interface Props {
  questions: Array<{
    question: string;
    answer: string;
  }>;
}

const { questions } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": questions.map(q => ({
    "@type": "Question",
    "name": q.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": q.answer
    }
  }))
};

// Escape "<" so content can never terminate the script tag early.
const safeJson = JSON.stringify(faqSchema).replace(/</g, "\\u003c");
---

<script type="application/ld+json" set:html={safeJson} />
