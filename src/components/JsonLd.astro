---
import { BUSINESS_INFO } from '@/consts';

interface Props {
  type?: 'LocalBusiness' | 'Organization' | 'Article';
  data?: Record<string, any>;
}

const { type = 'LocalBusiness', data = {} } = Astro.props;

// Base data for LocalBusiness (pulled from centralized BUSINESS_INFO)
const localBusinessData = {
  "@context": "https://schema.org",
  "@type": "VideoProductionService",
  "@id": `${BUSINESS_INFO.url}/#business`,
  "name": BUSINESS_INFO.name,
  "alternateName": BUSINESS_INFO.alternateName,
  "description": BUSINESS_INFO.description,
  "image": BUSINESS_INFO.image,
  "logo": {
    "@type": "ImageObject",
    "url": BUSINESS_INFO.logo,
  },
  "url": BUSINESS_INFO.url,
  "telephone": BUSINESS_INFO.telephone,
  "email": BUSINESS_INFO.email,
  "foundingDate": "2019",
  "address": {
    "@type": "PostalAddress",
    ...BUSINESS_INFO.address,
  },
  "geo": {
    "@type": "GeoCoordinates",
    ...BUSINESS_INFO.geo,
  },
  "areaServed": BUSINESS_INFO.areaServed.map((area) => ({
    "@type": area.type,
    "name": area.name,
    ...(area.sameAs ? { "sameAs": area.sameAs } : {}),
  })),
  "knowsAbout": BUSINESS_INFO.knowsAbout,
  "priceRange": BUSINESS_INFO.priceRange,
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
    ],
    "opens": "09:00",
    "closes": "17:00",
  },
  "sameAs": [
    ...BUSINESS_INFO.social,
    BUSINESS_INFO.googleBusinessProfile,
  ],
};

// Logic to determine final schema based on type
let finalSchema = {};

if (type === 'LocalBusiness') {
  finalSchema = { ...localBusinessData, ...data };
} else {
  // Fallback for other types if needed in future
  finalSchema = {
    "@context": "https://schema.org",
    "@type": type,
    ...data,
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />
