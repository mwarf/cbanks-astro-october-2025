---
import { format } from "date-fns";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { Badge } from "@/components/ui/badge";
import { readingTime } from "@/lib/reading-time";
import TableOfContents from "./TableOfContents.astro";
import SocialShare from "./SocialShare.astro";

interface Props {
  post: CollectionEntry<"blog">;
  relatedPosts?: CollectionEntry<"blog">[];
  headings?: { depth: number; slug: string; text: string }[];
}

const { post, relatedPosts = [], headings = [] } = Astro.props;
const { title, author, image, pubDate, updatedDate, description } = post.data;

const authorName = author || "Coalbanks Creative";
const postUrl = new URL(Astro.url.pathname, Astro.site || Astro.url.origin).toString();

// Article JSON-LD
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": new URL(image || "/og-image.jpg", Astro.site || Astro.url.origin).toString(),
  "datePublished": pubDate.toISOString(),
  ...(updatedDate && { "dateModified": updatedDate.toISOString() }),
  "author": {
    "@type": "Person",
    "name": authorName
  },
  "publisher": {
    "@type": "Organization",
    "name": "Coalbanks Creative Inc.",
    "logo": {
      "@type": "ImageObject",
      "url": new URL("/logo-coalbanks.svg", Astro.site || Astro.url.origin).toString()
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.toString()
  }
};
// JSON.stringify does not escape "</script>"; escape "<" so frontmatter
// content can never terminate the script tag early.
const articleJsonLdSafe = JSON.stringify(articleJsonLd).replace(/</g, "\\u003c");

const showToc = headings.some((h) => h.depth === 2 || h.depth === 3);
---

<section>
  <div class="container">
    <div class="mx-auto flex max-w-5xl flex-col items-center gap-5 text-center">
      <h1 class="font-display max-w-3xl text-4xl font-bold text-balance md:text-5xl">{title}</h1>
      <p class="text-muted-foreground max-w-2xl text-lg text-pretty md:text-xl">{description}</p>

      <div class="text-muted-foreground flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-sm">
        <span class="text-foreground font-semibold">{authorName}</span>
        <span aria-hidden="true">&middot;</span>
        <time datetime={pubDate.toISOString()}>{format(pubDate, "MMMM d, yyyy")}</time>
        {updatedDate && (
          <>
            <span aria-hidden="true">&middot;</span>
            <span>Updated <time datetime={updatedDate.toISOString()}>{format(updatedDate, "MMMM d, yyyy")}</time></span>
          </>
        )}
        <span aria-hidden="true">&middot;</span>
        <span>{readingTime(post.body)}</span>
      </div>

      <SocialShare url={postUrl} title={title} className="mt-2" />

      <script type="application/ld+json" set:html={articleJsonLdSafe} />

      <Image
        src={image || "/images/blog-placeholder-1.png"}
        alt=""
        width={1200}
        height={675}
        loading="eager"
        fetchpriority="high"
        class="mt-8 mb-8 aspect-video w-full rounded-2xl border object-cover shadow-md"
      />
    </div>
  </div>
  <div class="container pb-12">
    <div class="mx-auto max-w-5xl flex flex-col lg:flex-row gap-12 relative">
      <div class="prose prose-lg dark:prose-invert flex-1 max-w-none">
        <slot />
        <div class="mt-16 pt-8 border-t">
          <h2 class="text-base font-bold mb-4">Enjoyed this article? Share it with your network:</h2>
          <SocialShare url={postUrl} title={title} />
        </div>
      </div>
      {showToc && (
        <aside class="hidden lg:block lg:w-64">
          <TableOfContents headings={headings} />
        </aside>
      )}
    </div>
  </div>

  {/* Related Posts Section */}
  {relatedPosts.length > 0 && (
    <div class="container mt-24">
      <div class="mx-auto max-w-5xl">
        <h2 class="mb-8 text-2xl font-bold">Read Next</h2>
        <div class="grid gap-8 md:grid-cols-3">
          {relatedPosts.map((relatedPost) => (
            <a
              href={`/blog/${relatedPost.id}/`}
              class="group flex flex-col overflow-hidden rounded-xl border bg-card transition-shadow duration-300 hover:shadow-md"
            >
              <div class="overflow-hidden aspect-video">
                 <Image
                  src={relatedPost.data.image || "/images/blog-placeholder-1.png"}
                  alt=""
                  width={400}
                  height={225}
                  class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
                />
              </div>
              <div class="flex flex-1 flex-col p-4">
                <h3 class="mb-2 text-lg font-bold leading-tight group-hover:text-primary transition-colors line-clamp-2">
                  {relatedPost.data.title}
                </h3>
                <div class="mt-auto flex items-center justify-between gap-4 pt-4">
                    <time class="text-xs text-muted-foreground" datetime={relatedPost.data.pubDate.toISOString()}>
                        {format(relatedPost.data.pubDate, "MMM d, yyyy")}
                    </time>
                     <Badge variant="secondary" className="text-[10px] h-fit px-1.5 py-0.5 font-normal">
                      {readingTime(relatedPost.body)}
                    </Badge>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}
</section>
