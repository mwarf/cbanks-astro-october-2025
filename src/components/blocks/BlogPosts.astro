---
import { format } from "date-fns";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { Badge } from "@/components/ui/badge";
import { Separator } from "@/components/ui/separator";
import { readingTime } from "@/lib/reading-time";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;

const featuredPost = posts[0];
const regularPosts = posts.slice(1);
---

<section class="container mx-auto max-w-6xl px-4 py-8">
  {/* Featured Post */}
  {featuredPost && (
    <div class="mb-12 grid gap-8 md:grid-cols-2 lg:gap-12 items-center">
      <a
        href={`/blog/${featuredPost.id}/`}
        class="group block overflow-hidden rounded-2xl"
        tabindex="-1"
        aria-hidden="true"
      >
        <Image
          src={featuredPost.data.image || "/images/blog-placeholder-1.png"}
          alt=""
          width={800}
          height={450}
          loading="eager"
          fetchpriority="high"
          class="aspect-video w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
        />
      </a>
      <div class="flex flex-col justify-center space-y-4">
        <Badge variant="secondary" className="w-fit">
          Latest Article
        </Badge>
        <a href={`/blog/${featuredPost.id}/`}>
           <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight tracking-tight mb-4 hover:text-primary transition-colors text-balance">
            {featuredPost.data.title}
          </h2>
        </a>
        <p class="text-muted-foreground text-lg line-clamp-3 mb-6">
          {featuredPost.data.description}
        </p>
        <div class="flex items-center gap-4 pt-4 text-left">
          <div class="flex flex-col">
              <span class="text-sm font-semibold">{featuredPost.data.author || "Coalbanks Creative"}</span>
              <span class="text-xs text-muted-foreground">
                {format(featuredPost.data.pubDate, "MMMM d, yyyy")} &middot; {readingTime(featuredPost.body)}
              </span>
          </div>
        </div>
      </div>
    </div>
  )}

  {regularPosts.length > 0 && <Separator className="my-12" />}

  {/* Regular Posts Grid */}
  <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
    {regularPosts.map((post) => (
      <a
        class="group flex h-full flex-col overflow-hidden rounded-xl border bg-card text-card-foreground transition-shadow duration-300 hover:shadow-md"
        href={`/blog/${post.id}/`}
      >
        <div class="overflow-hidden">
          <Image
            src={post.data.image || "/images/blog-placeholder-1.png"}
            alt=""
            width={400}
            height={225}
            class="aspect-video w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
          />
        </div>
        <div class="flex flex-1 flex-col p-6">
          <h3 class="mb-3 text-xl font-bold leading-snug group-hover:text-primary transition-colors">
            {post.data.title}
          </h3>
          <p class="mb-6 line-clamp-2 text-sm text-muted-foreground flex-1">
            {post.data.description}
          </p>

          <div class="mt-auto flex items-center justify-between gap-4">
            <time class="text-xs font-medium text-muted-foreground" datetime={post.data.pubDate.toISOString()}>
              {format(post.data.pubDate, "MMM d, yyyy")}
            </time>
            <Badge variant="secondary" className="text-xs font-normal">
              {readingTime(post.body)}
            </Badge>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
