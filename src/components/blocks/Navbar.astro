---
import ThemeToggle from "@/components/ThemeToggle.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";

const ITEMS = [
  { label: "About", href: "/about" },
  { label: "Portfolio", href: "/portfolio" },
  { label: "Blog", href: "/blog" },
  { label: "FAQ", href: "/faq" },
  { label: "Contact", href: "/contact" },
];

const { pathname = "" } = Astro.props;
const isActive = (href: string) =>
  pathname === href || pathname.startsWith(`${href}/`);
---

<nav
  id="main-nav"
  aria-label="Main"
  class={cn(
    "bg-background/70 absolute left-1/2 z-50 w-[min(90%,700px)] -translate-x-1/2 rounded-4xl border shadow-sm backdrop-blur-md",
    "top-5 lg:top-12",
  )}
>
  <div class="flex items-center justify-between px-6 py-3">
    <a href="/" class="flex shrink-0 items-center gap-2" aria-label="Coalbanks — home">
      <img
        src="/logo-coalbanks.svg"
        alt="Coalbanks"
        width={94}
        height={18}
        class="dark:invert"
      />
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden lg:flex items-center gap-1">
      {ITEMS.map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? "page" : undefined}
          class={cn(
            "rounded-full px-3 py-1.5 text-sm font-medium transition-colors",
            isActive(link.href)
              ? "bg-muted text-foreground"
              : "text-muted-foreground hover:bg-muted/60 hover:text-foreground"
          )}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Theme Toggle & CTA -->
    <div class="flex items-center gap-2.5">
      <ThemeToggle />
      <a
        href="/contact"
        class={cn(buttonVariants(), "hidden rounded-full lg:inline-flex")}
      >
        Start a Project
      </a>
      <!-- Mobile Toggle -->
      <button
        id="mobile-menu-toggle"
        class="text-muted-foreground relative flex size-8 lg:hidden items-center justify-center"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <div class="relative w-[18px] h-[14px]">
          <span class="line absolute block h-0.5 w-full rounded-full bg-current transition-all duration-300 ease-in-out top-0"></span>
          <span class="line absolute block h-0.5 w-full rounded-full bg-current transition-all duration-300 ease-in-out top-[6px]"></span>
          <span class="line absolute block h-0.5 w-full rounded-full bg-current transition-all duration-300 ease-in-out top-[12px]"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Content -->
  <div
    id="mobile-menu"
    class="bg-background invisible absolute inset-x-0 top-[calc(100%+0.75rem)] flex -translate-y-4 flex-col rounded-2xl border p-6 opacity-0 shadow-xl transition-all duration-300 ease-in-out lg:hidden"
  >
    <nav aria-label="Mobile" class="divide-border flex flex-1 flex-col divide-y">
      {ITEMS.map((link) => (
        <div class="py-4 first:pt-0 last:pb-0">
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class={cn(
              "block text-base font-medium transition-colors",
              isActive(link.href)
                ? "text-foreground"
                : "text-muted-foreground hover:text-foreground"
            )}
          >
            {link.label}
          </a>
        </div>
      ))}
      <div class="pt-5">
        <a href="/contact" class={cn(buttonVariants(), "w-full rounded-full")}>
          Start a Project
        </a>
      </div>
    </nav>
  </div>
</nav>

<script>
  // Re-initialized on every view transition; the AbortController tears down
  // the previous page's document-level listeners so they don't accumulate.
  let teardown: AbortController | undefined;

  function initNav() {
    teardown?.abort();

    const toggle = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    if (!toggle || !menu) return;

    teardown = new AbortController();
    const { signal } = teardown;
    const lines = toggle.querySelectorAll(".line");
    let isOpen = false;

    const setOpen = (open: boolean) => {
      isOpen = open;
      toggle.setAttribute("aria-expanded", String(open));
      menu.classList.toggle("invisible", !open);
      menu.classList.toggle("-translate-y-4", !open);
      menu.classList.toggle("opacity-0", !open);

      // Morph hamburger into an X
      lines[0]?.classList.toggle("rotate-45", open);
      lines[0]?.classList.toggle("translate-y-[6px]", open);
      lines[1]?.classList.toggle("opacity-0", open);
      lines[2]?.classList.toggle("-rotate-45", open);
      lines[2]?.classList.toggle("-translate-y-[6px]", open);
    };

    toggle.addEventListener("click", () => setOpen(!isOpen), { signal });

    // Close on outside click
    document.addEventListener(
      "click",
      (event) => {
        const target = event.target as Node;
        if (isOpen && !menu.contains(target) && !toggle.contains(target)) {
          setOpen(false);
        }
      },
      { signal },
    );

    // Close on Escape
    document.addEventListener(
      "keydown",
      (event) => {
        if (isOpen && event.key === "Escape") {
          setOpen(false);
          (toggle as HTMLElement).focus();
        }
      },
      { signal },
    );

    // Close when a menu link is chosen
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false), { signal });
    });
  }

  initNav();
  document.addEventListener("astro:after-swap", initNav);
</script>
