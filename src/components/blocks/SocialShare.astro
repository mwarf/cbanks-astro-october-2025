---
import { Twitter, Linkedin, Facebook, Link as LinkIcon } from "lucide-react";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import { getShareUrls } from "@/lib/share-urls";

interface Props {
  url: string;
  title: string;
  className?: string;
}

const { url, title, className } = Astro.props;
const shareUrls = getShareUrls(url, title);

const iconButton = cn(
  buttonVariants({ variant: "outline", size: "icon" }),
  "h-8 w-8 rounded-full",
);
---

<div class:list={["flex items-center gap-2", className]}>
  <span class="text-xs font-medium text-muted-foreground mr-2">Share</span>

  <a href={shareUrls.twitter} target="_blank" rel="noopener noreferrer" aria-label="Share on X" title="Share on X" class={iconButton}>
    <Twitter className="h-4 w-4" aria-hidden="true" />
  </a>

  <a href={shareUrls.linkedin} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn" title="Share on LinkedIn" class={iconButton}>
    <Linkedin className="h-4 w-4" aria-hidden="true" />
  </a>

  <a href={shareUrls.facebook} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" title="Share on Facebook" class={iconButton}>
    <Facebook className="h-4 w-4" aria-hidden="true" />
  </a>

  <button type="button" class={cn(iconButton, "copy-link-btn")} aria-label="Copy link" title="Copy link" data-url={url}>
    <LinkIcon className="h-4 w-4" aria-hidden="true" />
  </button>
</div>

<script>
  const CHECK_ICON =
    '<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>';

  function initShareButtons() {
    document.querySelectorAll<HTMLButtonElement>(".copy-link-btn").forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = "true";

      btn.addEventListener("click", async () => {
        const url = btn.getAttribute("data-url");
        if (!url) return;
        try {
          await navigator.clipboard.writeText(url);
          const originalContent = btn.innerHTML;
          btn.innerHTML = CHECK_ICON;
          btn.setAttribute("aria-label", "Link copied");
          setTimeout(() => {
            btn.innerHTML = originalContent;
            btn.setAttribute("aria-label", "Copy link");
          }, 2000);
        } catch (err) {
          console.error("Failed to copy: ", err);
        }
      });
    });
  }

  initShareButtons();
  document.addEventListener("astro:after-swap", initShareButtons);
</script>
