---
import { ArrowLeft } from "lucide-react";

import Background from "@/components/Background.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
---

<DefaultLayout title="404: Not Found" description="Sorry, the page you're looking for doesn't exist.">
  <Background>
    <div class="container flex min-h-[70vh] flex-col items-center justify-center py-28 text-center lg:min-h-[80vh] lg:py-32">
      <div class="relative z-10 max-w-2xl">
        <h1 class="font-display from-foreground to-foreground/70 relative mb-6 bg-linear-to-br bg-clip-text py-2 text-5xl font-bold text-transparent sm:text-6xl lg:text-7xl">
          Page Not Found
        </h1>

        <p class="text-muted-foreground mb-10 text-xl">
          This page didn't make the final cut. The URL might have changed, or
          it never existed in the first place.
        </p>

        <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href="/" class={cn(buttonVariants({ size: "lg" }), "group min-w-[200px] gap-2")}>
            <ArrowLeft className="size-5 transition-transform group-hover:-translate-x-1" aria-hidden="true" />
            Back to Home
          </a>
          <a href="/portfolio" class={cn(buttonVariants({ variant: "outline", size: "lg" }), "min-w-[200px]")}>
            Watch Our Films
          </a>
        </div>
      </div>
    </div>
  </Background>
</DefaultLayout> 