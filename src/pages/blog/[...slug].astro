---
import { type CollectionEntry, getCollection } from 'astro:content';
import { render } from 'astro:content';

import BlogPost from '@/components/blocks/BlogPost.astro';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import BreadcrumbSchema from '@/components/BreadcrumbSchema.astro';
import { SITE_URL } from '@/consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { title, description, image, tags } = post.data;
const { Content, headings } = await render(post);

// BlogPosting structured data. Author/publisher reference the LocalBusiness
// node emitted by BaseHead so each article is tied to the business entity.
const postUrl = new URL(`/blog/${post.id}`, Astro.site).href;
const articleSchema = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: title,
	description,
	...(image ? { image: new URL(image, Astro.site).href } : {}),
	datePublished: post.data.pubDate.toISOString(),
	dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
	author: { "@id": `${SITE_URL}/#business` },
	publisher: { "@id": `${SITE_URL}/#business` },
	mainEntityOfPage: { "@type": "WebPage", "@id": postUrl },
	...(tags.length > 0 ? { keywords: tags.join(", ") } : {}),
};
const safeArticleJson = JSON.stringify(articleSchema).replace(/</g, "\\u003c");

// Fetch related posts (prioritize matching tags, then recency)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => {
    if (tags.length > 0) {
      const aScore = a.data.tags.filter((t) => tags.includes(t)).length;
      const bScore = b.data.tags.filter((t) => tags.includes(t)).length;
      if (bScore !== aScore) return bScore - aScore;
    }
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 3);


---
<DefaultLayout title={title} description={description} image={image} ogType="article">
	<script type="application/ld+json" set:html={safeArticleJson} />
	<BreadcrumbSchema items={[
		{ name: "Home", url: "/" },
		{ name: "Blog", url: "/blog" },
		{ name: title, url: `/blog/${post.id}` }
	]} />
	<div class="py-28 lg:pt-44 lg:pb-32">
		<BlogPost post={post} relatedPosts={relatedPosts} headings={headings}>
			<Content />
		</BlogPost>
	</div>
</DefaultLayout>