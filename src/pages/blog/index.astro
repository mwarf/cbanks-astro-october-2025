---
import { getCollection } from 'astro:content';

import Background from "@/components/Background.astro";

import BlogPosts from '@/components/blocks/BlogPosts.astro';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import BreadcrumbSchema from '@/components/BreadcrumbSchema.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<DefaultLayout
  title="Field Notes | Video Production Blog | Coalbanks"
  description="What 65+ shoots taught us about process, pricing, and getting real stories on camera. Video production advice from Southern Alberta's documentary filmmakers."
>
	<BreadcrumbSchema items={[
		{ name: "Home", url: "/" },
		{ name: "Blog", url: "/blog" }
	]} />
	<Background>
		<div class="container flex max-w-5xl flex-col justify-between gap-8 md:gap-20 lg:flex-row lg:items-center lg:gap-24 xl:gap-24 pt-28 lg:pt-44 lg:pb-16">
			<div class="flex-[1.5]">
				<h1 class="font-display font-bold text-3xl tracking-tight sm:text-4xl md:text-5xl lg:text-6xl">
					Field Notes
				</h1>

				<p class="text-muted-foreground mt-5 text-2xl md:text-3xl lg:text-4xl">
					What 65+ shoots taught us about process, pricing, and getting real stories on camera.
				</p>
			</div>
		</div>
		<div class="pb-28 lg:pb-32">
			<BlogPosts posts={posts} />
		</div>
	</Background>
</DefaultLayout>

