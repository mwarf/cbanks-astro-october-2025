---
import Background from "@/components/Background.astro";

import { Contact as ContactBlock } from '@/components/blocks/contact';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import BreadcrumbSchema from '@/components/BreadcrumbSchema.astro';
---
<DefaultLayout
  title="Contact Coalbanks | Get a Video Production Quote | Lethbridge"
  description="Contact Coalbanks for video production services in Lethbridge and Southern Alberta. Free discovery call to discuss your project."
>
  <BreadcrumbSchema items={[
    { name: "Home", url: "/" },
    { name: "Contact", url: "/contact" }
  ]} />
  <Background>
    <div class="container flex max-w-5xl flex-col justify-between gap-8 md:gap-20 lg:flex-row lg:items-center lg:gap-24 xl:gap-24 pt-28 lg:pt-44 lg:pb-16">
      <div class="flex-[1.5]">
        <h1 class="font-display font-bold text-3xl tracking-tight sm:text-4xl md:text-5xl lg:text-6xl">
          Let's Build Something Real
        </h1>

        <p class="text-muted-foreground mt-5 text-2xl md:text-3xl lg:text-4xl">
          We build films that people actually watch. Tell us about your project.
        </p>
      </div>
    </div>
    <ContactBlock client:load />
  </Background>
</DefaultLayout>
