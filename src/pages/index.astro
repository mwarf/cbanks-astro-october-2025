---
import Background from '@/components/Background.astro';
import { FAQ } from '@/components/blocks/faq';
import Hero from '@/components/blocks/Hero.astro';
import ResourceAllocation from '@/components/blocks/ResourceAllocation.astro';
import { ProcessSection } from '@/components/blocks/process-section';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { homepageFAQCategories } from '@/data/faq';

import heroMain from '@/assets/images/home/hero-main.png';
import heroSecondary1 from '@/assets/images/home/feature-1.jpg';
import heroSecondary2 from '@/assets/images/home/feature-2.jpg';


---

<DefaultLayout 
  title="Video Production Lethbridge | Documentary Films for Southern Alberta Businesses | Coalbanks"
  description="Professional video production in Lethbridge and Southern Alberta. Documentary-style brand films, recruitment videos, and corporate storytelling that drives results."
>
  <Background className="via-muted to-muted/80">
    <Hero images={[heroMain, heroSecondary1, heroSecondary2]} />
    <ResourceAllocation />
    <ProcessSection />
  </Background>
  <Background variant="bottom">
    <!-- Local SEO: crawlable copy targeting "Lethbridge videographer" queries -->
    <section class="container py-28 lg:py-32">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-3xl tracking-tight text-balance sm:text-4xl md:text-5xl">
          Video production in Lethbridge, for all of Southern Alberta
        </h2>
        <p class="text-muted-foreground mt-6 text-lg leading-relaxed">
          Coalbanks is a video production company based in Lethbridge — our
          studio sits on 28 Street North, and most of our films are shot within
          a few hours of it. Since 2019 we've made 65+ films for businesses,
          municipalities, and nonprofits in Lethbridge, Medicine Hat, Taber,
          Cardston, and as far out as Calgary and Cranbrook.
        </p>
        <p class="text-muted-foreground mt-4 text-lg leading-relaxed">
          If you're comparing
          <a href="/services/videography" class="text-foreground underline underline-offset-4 hover:no-underline">Lethbridge videographers</a>,
          start with the work:
          <a href="/portfolio" class="text-foreground underline underline-offset-4 hover:no-underline">watch our films</a>,
          then see our
          <a href="/services/production" class="text-foreground underline underline-offset-4 hover:no-underline">corporate video production services</a>.
        </p>
      </div>
    </section>

    <FAQ client:visible categories={homepageFAQCategories}/>
  </Background>
</DefaultLayout>