---
import { Film, Search, Calendar, Plane, ArrowUpRight, ArrowRight } from "lucide-react";

import DefaultLayout from "@/layouts/DefaultLayout.astro";
import Background from "@/components/Background.astro";
import ServiceGrid from "@/components/blocks/ServiceGrid.astro";
import { ServiceFAQ } from "@/components/blocks/service-faq";
import ServiceCTA from "@/components/blocks/ServiceCTA.astro";
import BreadcrumbSchema from "@/components/BreadcrumbSchema.astro";
import { DashedLine } from "@/components/dashed-line";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import { BUSINESS_INFO } from "@/consts";

// Service Page JSON-LD. Provider references the LocalBusiness node emitted by
// BaseHead on every page, so business details live in one place.
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Videography",
  "name": "Lethbridge Videography Services",
  "description":
    "Documentary-style videography for Southern Alberta businesses: brand films, recruitment videos, event coverage, and licensed drone cinematography.",
  "provider": {
    "@id": `${BUSINESS_INFO.url}/#business`,
  },
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": "Southern Alberta",
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "CAD",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "minPrice": 1500,
      "priceCurrency": "CAD",
    },
    "description":
      "Event and aerial coverage from $1,500 CAD; documentary brand films from $8,000 CAD",
  },
};

// Verified stats for the hero (interview-confirmed July 2026)
const heroStats = [
  { value: "65+", label: "films for Southern Alberta organizations since 2019" },
  { value: "4–6 wks", label: "from discovery call to delivered film" },
  { value: "300 km", label: "service radius from our Lethbridge studio" },
];

// What we film
const serviceTypes = [
  {
    title: "Brand Documentaries",
    description:
      "8-15 minute films that explain who you are and why it matters. Built for your homepage, investor presentations, and recruitment.",
    icon: Film,
  },
  {
    title: "Recruitment Films",
    description:
      "Videos that attract the right talent by showing your culture and the real people who make your organization work.",
    icon: Search,
  },
  {
    title: "Event Coverage",
    description:
      "Multi-camera filming for conferences, galas, groundbreakings, and community gatherings across Southern Alberta.",
    icon: Calendar,
  },
  {
    title: "Aerial & Drone",
    description:
      "Transport Canada certified pilots with commercial insurance. Facility tours, agriculture, construction, and real estate from above.",
    icon: Plane,
  },
];

// Featured work — typographic index, no thumbnails (real images come later).
// Categories mirror the portfolio entries' frontmatter.
const featuredProjects = [
  {
    title: "Tradesman Manufacturing",
    client: "Tradesman Manufacturing",
    category: "Industrial & Commercial",
    slug: "/portfolio/tradesman-manufacturing",
  },
  {
    title: "MD of Taber 70th Anniversary",
    client: "Municipal District of Taber",
    category: "Community & Municipal",
    slug: "/portfolio/md-taber-70th-anniversary",
  },
  {
    title: "Team Lethbridge Mission",
    client: "Economic Development Lethbridge",
    category: "Community & Municipal",
    slug: "/portfolio/team-lethbridge-mission-edl",
  },
];

// FAQ — every claim verified with Michael, July 2026
const faqQuestions = [
  {
    question: "What does hiring a videographer in Lethbridge cost?",
    answer:
      "It depends on what you're making. Event coverage and aerial work start at $1,500. Documentary-style story packages start at $8,000, and our signature brand documentaries start at $15,000. Headshot photography can be added to any shoot from $150 per person. Every project gets a custom quote after a free discovery call.",
  },
  {
    question: "Where do you film?",
    answer:
      "We're based at 1401 28 St N in Lethbridge and work across Southern Alberta — Medicine Hat, Taber, Cardston, and everywhere in between. We regularly travel within 300km of Lethbridge, including Calgary and Cranbrook.",
  },
  {
    question: "What kind of videography do you do?",
    answer:
      "Documentary-style storytelling is our specialty: brand documentaries, recruitment films, and investor or stakeholder videos. We also cover events (conferences, galas, groundbreakings), fly licensed drone missions, and shoot commercial photography alongside video productions.",
  },
  {
    question: "How long does a video project take?",
    answer:
      "Brand documentaries take 4-6 weeks from discovery to delivery: 1-2 weeks finding the story, 2-3 days of filming, and 2-3 weeks of post-production. Event edits are delivered within 2-3 weeks of your event. Rush delivery is available for an additional fee.",
  },
  {
    question: "What equipment do you use?",
    answer:
      "We film with cinema cameras (RED and Sony FX series) and professional audio. For aerial work, our pilots hold Transport Canada Advanced Operations certificates, carry $5M commercial liability insurance, and fly DJI Inspire 3, Mavic 3 Cine, and FPV systems.",
  },
  {
    question: "How far in advance should I book?",
    answer:
      "We take on 12-15 projects per year to keep the quality high, which means we typically book 2-3 months out during busy seasons. If you have a date or deadline in mind, reach out early.",
  },
];
---

<DefaultLayout
  title="Lethbridge Videographer | Documentary Films & Video | Coalbanks"
  description="Looking for a videographer in Lethbridge? Coalbanks makes documentary-style films for Southern Alberta businesses — brand films, events, and drone coverage since 2019."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <BreadcrumbSchema items={[
    { name: "Home", url: "/" },
    { name: "Videography", url: "/services/videography" }
  ]} />
  <Background className="via-muted to-muted/80">
    <!-- Hero: type-driven, no imagery -->
    <section class="py-28 lg:pt-44 lg:pb-32">
      <div class="container">
        <p class="text-primary text-sm font-semibold uppercase tracking-wider">
          Lethbridge Videography
        </p>

        <h1 class="h1 text-foreground mt-6 max-w-[18ch] text-balance">
          A Lethbridge videographer who starts with the story
        </h1>

        <p class="text-muted-foreground mt-8 max-w-2xl text-lg leading-relaxed sm:text-xl lg:text-2xl">
          We're Coalbanks — a documentary video production company based in
          Lethbridge, making films for the businesses, municipalities, and
          nonprofits of Southern Alberta.
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href="/contact" class={buttonVariants({ size: "lg" })}>
            Start a Discovery Call
          </a>
          <a
            href="/portfolio"
            class={cn(buttonVariants({ variant: "outline", size: "lg" }), "group gap-2")}
          >
            Watch Our Work
            <ArrowRight className="size-4 transition-transform group-hover:translate-x-0.5" aria-hidden="true" />
          </a>
        </div>

        <DashedLine orientation="horizontal" className="mt-16" />

        <dl class="mt-10 grid gap-10 sm:grid-cols-3">
          {heroStats.map((stat) => (
            <div>
              <dt class="sr-only">{stat.label}</dt>
              <dd class="font-display text-4xl font-bold tracking-tight lg:text-5xl">
                {stat.value}
              </dd>
              <p class="text-muted-foreground mt-2 max-w-[28ch] text-sm leading-snug">
                {stat.label}
              </p>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- What We Film -->
    <ServiceGrid
      title="What We Film"
      description="One team for the whole job — story-driven films, event coverage, and licensed aerial work."
      items={serviceTypes}
      columns={4}
    />
  </Background>

    <!-- Featured Work: typographic index -->
    <section class="container py-28 lg:py-32">
      <div class="mx-auto max-w-4xl">
        <h2 class="text-3xl tracking-tight text-balance sm:text-4xl md:text-5xl">
          Recent Work
        </h2>
        <p class="text-muted-foreground mt-4 text-lg">
          Films for Lethbridge and Southern Alberta municipalities,
          manufacturers, and nonprofits.
        </p>

        <div class="mt-12 border-t">
          {featuredProjects.map((project, index) => (
            <a
              href={project.slug}
              class="group flex items-baseline gap-6 border-b py-8 transition-colors hover:bg-muted/40 sm:gap-10"
            >
              <span class="text-muted-foreground/60 font-mono text-sm tabular-nums">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span class="flex-1">
                <span class="h3 text-foreground group-hover:text-primary block transition-colors">
                  {project.title}
                </span>
                <span class="text-muted-foreground mt-1 block text-sm">
                  {project.client} &middot; {project.category}
                </span>
              </span>
              <ArrowUpRight
                className="text-muted-foreground group-hover:text-primary size-5 shrink-0 self-center transition-all group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                aria-hidden="true"
              />
            </a>
          ))}
        </div>

        <a
          href="/portfolio"
          class="text-foreground group mt-8 inline-flex items-center gap-2 font-medium underline underline-offset-4 hover:no-underline"
        >
          See the full portfolio
          <ArrowRight className="size-4 transition-transform group-hover:translate-x-0.5" aria-hidden="true" />
        </a>
      </div>
    </section>

    <!-- Local context: crawlable copy for "Lethbridge videographer" queries -->
    <section class="container pb-28 lg:pb-32">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-3xl tracking-tight text-balance sm:text-4xl md:text-5xl">
          Why hire a local videographer?
        </h2>
        <p class="text-muted-foreground mt-6 text-lg leading-relaxed">
          Because the story is here. We know what a chinook does to an
          afternoon of filming, which side of the coulees catches the good
          light, and who to call when a shoot needs a location by Friday.
          Being based in Lethbridge means shorter travel bills, faster
          scheduling, and a crew that already understands who you're talking
          to.
        </p>
        <p class="text-muted-foreground mt-4 text-lg leading-relaxed">
          Our signature offering is the
          <a href="/services/production" class="text-foreground underline underline-offset-4 hover:no-underline">documentary-style brand film</a>
          — but every project starts the same way: a conversation about what
          you're trying to do, not a package off a shelf.
          <a href="/portfolio" class="text-foreground underline underline-offset-4 hover:no-underline">Watch the work</a>
          and judge for yourself.
        </p>
      </div>
    </section>

  <Background variant="bottom">
    <!-- FAQ -->
    <ServiceFAQ
      client:visible
      questions={faqQuestions}
      title="Questions People Ask Before Hiring Us"
    />

    <!-- CTA -->
    <ServiceCTA
      title="Tell us what you're trying to say"
      description="Start with a free discovery call. No pitch — just questions about your business and what a film could do for it."
      buttonText="Start a Discovery Call"
      buttonHref="/contact"
      variant="centered"
    />
  </Background>
</DefaultLayout>
